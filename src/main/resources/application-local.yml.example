# 本地敏感配置示例
# 使用方式：复制此文件为 application-local.yml，填入真实值。application-local.yml 已被 .gitignore 忽略，不会提交到 Git。
#
# 也可通过环境变量配置，无需本文件：
#   DB_URL, DB_USERNAME, DB_PASSWORD
#   DASHSCOPE_API_KEY
#   SEARCH_API_KEY

spring:
  datasource:
    url: jdbc:postgresql://your-host:5432/your_db
    username: your_username
    password: your_password

  ai:
    dashscope:
      api-key: your-dashscope-api-key

search-api:
  api-key: your-search-api-key
